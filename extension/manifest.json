{
  "manifest_version": 3,
  "name": "JobFilter for Korea Jobs",
  "short_name": "JobFilter",
  "version": "0.2.0",
  "description": "Filter Korean job postings and mark companies you have already applied to.",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "JobFilter"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "commands": {
    "open-options": {
      "suggested_key": {
        "default": "Alt+Shift+J",
        "mac": "Alt+Shift+J"
      },
      "description": "JobFilter 관리 화면 열기"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.saramin.co.kr/*",
        "https://*.jobkorea.co.kr/*",
        "https://*.wanted.co.kr/*"
      ],
      "js": [
        "src/constants.js",
        "src/utils/companyName.js",
        "src/sites/jobkorea.js",
        "src/sites/saramin.js",
        "src/sites/wanted.js",
        "src/contentScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": [
    "https://*.saramin.co.kr/*",
    "https://*.jobkorea.co.kr/*",
    "https://*.wanted.co.kr/*"
  ]
}
